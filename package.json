{
  "name": "vscode-remote-try-honox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build --mode client && vite build",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "dev": "vite",
    "fix": "run-s fix:oxfmt fix:oxlint fix:prisma-case fix:prisma",
    "fix:oxfmt": "oxfmt",
    "fix:oxlint": "oxlint --fix",
    "fix:prisma": "prisma format",
    "fix:prisma-case": "prisma-case-format --file prisma/schema.prisma",
    "generate": "prisma generate",
    "lint": "run-p --aggregate-output -c -l lint:*",
    "lint:oxfmt": "oxfmt --check",
    "lint:oxlint": "oxlint",
    "preview": "wrangler dev",
    "setup": "corepack enable pnpm"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.54.1",
    "@hono/zod-validator": "^0.7.6",
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.7",
    "honox": "^0.1.55",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260310.1",
    "@commitlint/cli": "20.4.3",
    "@commitlint/config-conventional": "20.4.3",
    "@hono/vite-build": "1.10.0",
    "@hono/vite-dev-server": "0.25.1",
    "@tailwindcss/vite": "4.2.1",
    "@tsconfig/strictest": "2.0.8",
    "lefthook": "2.1.3",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.38.0",
    "oxlint": "1.53.0",
    "oxlint-tsgolint": "0.16.0",
    "prisma": "7.4.2",
    "prisma-case-format": "2.2.1",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "wrangler": "4.72.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.11.1",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@10.32.1"
}
